generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(20)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questionBanks QuestionBank[]
  createdVotes  Vote[]
  answers       Answer[]

  @@map("users")
}

model QuestionBank {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId Int
  creator   User @relation(fields: [creatorId], references: [id])

  questions Question[]
  votes     Vote[]

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

   @@map("question_banks")
}

model Question {
  id          Int     @id @default(autoincrement())
  text        String
  description String?
  imageUrl    String?
  bankId Int
  bank   QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  answers Answer[]

  @@map("questions")
}

model Vote {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(100)
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankId Int
  bank   QuestionBank @relation(fields: [bankId], references: [id])

  creatorId Int
  creator   User @relation(fields: [creatorId], references: [id])

  answers Answer[]

  @@map("votes")
}

model Answer {
  id        Int      @id @default(autoincrement())
  answer    Boolean
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  voteId Int
  vote   Vote @relation(fields: [voteId], references: [id])

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([userId, voteId, questionId])
  @@map("answers")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)
  slug  String @unique @db.VarChar(50)
  color String @default("#007AFF") @db.VarChar(7)

  banks     QuestionBank[]
  templates QuestionBankTemplate[]

  @@map("categories")
}

model QuestionBankTemplate {
  id          Int      @id @default(autoincrement())
  title       String   @unique @db.VarChar(100)
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  @@map("question_bank_templates")
}

model Media {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  imdbId      String    @unique @db.VarChar(20)
  imageUrl    String?
  mediaType   MediaType 

  platforms MediaPlatform[]

  @@map("media")
}

enum MediaType {
  MOVIE
  SERIES
  SHORTFILM
}

model Platform {
  name     String          @id @db.VarChar(100)
  imageUrl String?
  medias   MediaPlatform[]

  @@map("paltforms")
}

model MediaPlatform {
  id Int @id @default(autoincrement())

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id])

  platformName String   @db.VarChar(100)
  platform     Platform @relation(fields: [platformName], references: [name])

  @@unique([mediaId, platformName])
  @@map("media_platforms")
}
